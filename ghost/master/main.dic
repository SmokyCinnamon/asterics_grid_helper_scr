OnWordListExtractorMenu.OBF : all {
	FileToOpen = "%(reference2)"
	"\_q\0\s[0]\b[2]\n[half]\*"
	"\f[color,disable]Word list extractor\f[color,default]\n\n[half]"
	"Extract word list from an un-zipped obz file. (obz_folder/boards/)\n\n"
	"Folder Selected: %(FolderToOpen)\n\n"
	"%*\__q[OnFilePick,wordlistextractor.obf]Pick Folder\__q\n\n"
	"%*\__q[OnWordListExtractor.OBF]Extract word list from selected folder\__q\n\n"
	"\n[half]%*\__q[OnSakuraMenu]Main Menu\__q\n%*\__q[OnCloseMenu]Close menu\__q"
	"\_q"
}

OnFilePick {
	if reference0 == "wordlistextractor.txtgrd" {
		"\![open,dialog,open]"
	}
	elseif reference0 == "wordlistextractor.obf" {
		"\![open,dialog,folder]"
	}
}

OnSystemDialog {
	//LOGGING(FileToOpen)
	//LOGGING("can anyone hear meeee")
	//LOGGING(reference)
	if reference0 == "open" {
		FileToOpen = "%(reference2)"
		LOGGING(FileToOpen)
			--
			OnWordListExtractorMenu.TXTGRD //there has to be a better way
	}
	elseif reference0 == "folder" {
		FolderToOpen = "%(reference2)"
		--
		OnWordListExtractorMenu.OBF
	}
}

