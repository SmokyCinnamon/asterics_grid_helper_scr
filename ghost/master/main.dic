OnWordListExtractor.OBF {
	_folderFiles = FENUM(FolderToOpen)
	_folderFiles = SPLIT(_folderFiles,',')
	LOGGING(_folderFiles)
	
	_extractedFile = "exports/obf_word_list.txt"
	_f = FOPEN(_extractedFile,'w')
	
	foreach _folderFiles; _file {
		LOGGING(FolderToOpen)
		LOGGING(_file)
		_file = "%(FolderToOpen)" + "/%(_file)"
		LOGGING(_file)
		_f = FOPEN(_file,'r') //open file read mode
		LOGGING(_f)
		--
		for _buff = FREAD(_file); _buff != -1; _buff = FREAD(_file) {
			LOGGING("Buffer:")
			LOGGING(_buff)
			if RE_GREP(_buff,'("label"\:\"(.+?)\")')
			{
				LOGGING("Regex result:")
				_regexResult = RE_GETSTR
				LOGGING(_regexResult)
				foreach _regexResult; _arrayElement {
					LOGGING(_arrayElement)
					_word = ''
					if RE_SEARCH(_arrayElement,'("label"\:\"(.+?)\")')
					{
						//i dont need the whole thing again but why reinvent the wheel
						LOGGING("Second regex result (from array)")
						LOGGING(RE_GETSTR)
						_regexResultArray = RE_GETSTR
						_word = _regexResultArray[2]
					
						_f = FWRITE(_extractedFile,"%(_word)")
					}
				}
			}
		}
		_f = FCLOSE(_file)
	}
	_f = FCLOSE(_extractedFile)
	--
	"\![get,property,OnOpenExtracted,currentghost.path]"
}

OnOpenExtracted {
	_path = reference0
	_path = REPLACE(_path,'\','/')
	_path = _path + "ghost/master/exports/"
	"\_qCurrent path: %(_path)\_q\x\![open,dialog,open,--dir=%(_path)]"
}