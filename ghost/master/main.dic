On_homeurl {
	"https://raw.githubusercontent.com/SmokyCinnamon/asterics_grid_helper_scr/refs/heads/main/"
}


ghostver {
	"1.0.0"
}

OnBoot {
	FileToOpen = ""
	FolderToOpen = ""
	"\0\s[0]\1\s[-1] \e"
}

OnSurfaceRestore {
	"\0\s[0]\1\s[-1]\e"
}


OnMouseDoubleClick {
	//if reference4 == 0; 
	OnSakuraMenu
}

OnClose {
	"\0\-"
}


OnSakuraMenu : all {
	"\_q\0\s[0]\n[half]\*"
	"%*\__q[OnWordListExtractorMenu.OBF]Word list extractor\__q\n\n"
	"\n[half]%*\__q[OnCloseMenu]Close menu\__q\n"
	"%(ghostver)\_q"
}

