	"File Selected: %(FileToOpen)\n\n"
	"%*\__q[OnFilePick,wordlistextractor.txtgrd]Pick .GRD/.TXT File\__q\n\n"
	"%*\__q[OnWordListExtractor]Extract word list from selected file\__q\n\n"
	"\n[half]%*\__q[OnSakuraMenu]Main Menu\__q\n%*\__q[OnCloseMenu]Close menu\__q"
